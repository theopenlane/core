    "email.RuntimeEmailConfig": {
      "properties": {
        "testdir": {
          "type": "string",
          "description": "Directory for dev-mode email output"
        },
        "resendsecret": {
          "type": "string",
          "description": "Resend webhook signing secret"
        },
        "apikey": {
          "type": "string",
          "description": "Email provider API key"
        },
        "provider": {
          "type": "string",
          "enum": [
            "resend"
          ],
          "description": "Email service provider"
        },
        "fromemail": {
          "type": "string",
          "description": "Sender email address"
        },
        "supportemail": {
          "type": "string",
          "description": "Support contact email address"
        },
        "questionnaireemail": {
          "type": "string",
          "description": "Sender override for questionnaire auth emails"
        },
        "rooturl": {
          "type": "string",
          "description": "Root application URL used to construct email action links"
        },
        "producturl": {
          "type": "string",
          "description": "Product home URL"
        },
        "docsurl": {
          "type": "string",
          "description": "Documentation URL"
        },
        "apiurl": {
          "type": "string",
          "description": "Public base URL of the API for email links that hit the API directly"
        },
        "CompanyName": {
          "type": "string",
          "description": "Company display name"
        },
        "CompanyAddress": {
          "type": "string",
          "description": "Company mailing address"
        },
        "Corporation": {
          "type": "string",
          "description": "Legal corporation name"
        },
        "LogoURL": {
          "type": "string",
          "description": "Hero logo URL displayed in the email body"
        },
        "HeaderLogoURL": {
          "type": "string",
          "description": "Small logo or icon displayed in the top header bar"
        },
        "Copyright": {
          "type": "string",
          "description": "Copyright override for email footers; when empty the template renders a dynamic notice from Corporation and the current year"
        },
        "TroubleText": {
          "type": "string",
          "description": "Fallback help text shown below action buttons; {ACTION} is replaced with the button text at render time"
        },
        "TermsURL": {
          "type": "string",
          "description": "Terms of service link for email footers"
        },
        "PrivacyURL": {
          "type": "string",
          "description": "Privacy policy link for email footers"
        },
        "UnsubscribeURL": {
          "type": "string",
          "description": "Unsubscribe link override for email footers; when empty the template constructs one from ProductURL and the recipient email"
        },
        "HeaderText": {
          "type": "string",
          "description": "Text displayed in the upper-right corner of the modern theme header"
        },
        "CardStyle": {
          "type": "string",
          "enum": [
            "flat",
            "elevated"
          ],
          "description": "Card visual style"
        },
        "BodyBackgroundColor": {
          "type": "string",
          "description": "Outer page background color"
        },
        "CardBackgroundColor": {
          "type": "string",
          "description": "Card container background color"
        },
        "HeroBackgroundColor": {
          "type": "string",
          "description": "Hero banner section background color"
        },
        "ButtonColor": {
          "type": "string",
          "description": "Call-to-action button background color"
        },
        "ButtonTextColor": {
          "type": "string",
          "description": "Call-to-action button text color"
        },
        "HeadingColor": {
          "type": "string",
          "description": "Heading and title text color"
        },
        "TextColor": {
          "type": "string",
          "description": "Body paragraph text color"
        },
        "FooterTextColor": {
          "type": "string",
          "description": "Muted text color for headers footers and secondary content"
        },
        "AccentBorderColor": {
          "type": "string",
          "description": "Decorative accent color applied to borders only"
        },
        "Tagline": {
          "type": "string",
          "description": "Short descriptive footer line rendered above the social row in modern themes"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "apikey",
        "provider",
        "fromemail"
      ]
    },
