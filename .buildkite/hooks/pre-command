#!/bin/bash

set -euo pipefail

# normalizes a ssh url (git@github.com:theopenlane/core.git) to theopenlane/core.
# NOTE: not exactly sure if the pull request one will always come in this format or it
# would use https but we can always fix if that is the case as this function indexes on
# it being always ssh
owner_slug_format() {
  local url="${1:-}"
  [[ -z "$url" ]] && return 0
  url="${url%.git}"
  url=$(echo "$url" | tr '[:upper:]' '[:lower:]')
  if [[ "$url" =~ github\.com:([^/]+/[^/]+) ]]; then
    echo "${BASH_REMATCH[1]}"
  fi
}

OPENLANE_BUILDKITE_JOB_PRIORITY=0
# highest priority: releases tag.
if [[ -n "${BUILDKITE_TAG:-}" ]]; then
  OPENLANE_BUILDKITE_JOB_PRIORITY=100
# PRs: branches from same repo should be high priority while renovate/forks should get low priority.
elif [[ -n "${BUILDKITE_PULL_REQUEST:-}" && "${BUILDKITE_PULL_REQUEST}" != "false" ]]; then
  renovate=false
  [[ "${BUILDKITE_BRANCH:-}" =~ ^renovate/ ]] && renovate=true

  # find out if the PR is from a fork by comparing the source repo slug to pipeline repo slug.
  fork=false
  if [[ -n "${BUILDKITE_PULL_REQUEST_REPO:-}" && -n "${BUILDKITE_REPO:-}" ]]; then
    pr_repo_slug=$(owner_slug_format "${BUILDKITE_PULL_REQUEST_REPO}")
    pipeline_repo_slug=$(owner_slug_format "${BUILDKITE_REPO}")
    if [[ -n "$pr_repo_slug" && -n "$pipeline_repo_slug" && "$pr_repo_slug" != "$pipeline_repo_slug" ]]; then
      fork=true
    fi
  fi

  if [[ "$renovate" == true || "$fork" == true ]]; then
    OPENLANE_BUILDKITE_JOB_PRIORITY=-10
  else
    OPENLANE_BUILDKITE_JOB_PRIORITY=80
  fi

elif [[ "${BUILDKITE_BRANCH:-}" == "main" ]]; then
  OPENLANE_BUILDKITE_JOB_PRIORITY=50
# renovate commits on main branch are not prioritized too
elif [[ "${BUILDKITE_BRANCH:-}" =~ ^renovate/ ]]; then
  OPENLANE_BUILDKITE_JOB_PRIORITY=-10
fi

export OPENLANE_BUILDKITE_JOB_PRIORITY

echo "🔧 Setting up build environment..."

# Create cache directories (tools may not be available yet)
mkdir -p $HOME/.cache/go-build 2>/dev/null || true
mkdir -p $HOME/.cache/golangci-lint 2>/dev/null || true
mkdir -p $HOME/.cache/go/pkg/mod 2>/dev/null || true

# Docker layer caching setup (Docker handled via plugins)
export DOCKER_BUILDKIT=1
export COMPOSE_DOCKER_CLI_BUILD=1

# Basic tool availability checks (only for tools that should be on base VM)
echo "🔍 Checking base system tools..."
if ! command -v git >/dev/null 2>&1; then
  echo "❌ Git not found in PATH"
  exit 1
fi

# Common environment validation
if [[ -z "${BUILDKITE_BUILD_ID:-}" ]]; then
  echo "⚠️  Not running in Buildkite environment"
fi

# Create temporary directories for build artifacts
mkdir -p "${BUILDKITE_BUILD_PATH:-/tmp}/artifacts"
mkdir -p "${BUILDKITE_BUILD_PATH:-/tmp}/test-results"

# Check disk space before starting build
echo "📊 Checking disk space..."
if disk_usage=$(df -h . 2>/dev/null | tail -1 | awk '{print $5}' 2>/dev/null | sed 's/%//' 2>/dev/null) && [[ -n "$disk_usage" ]] && [[ "$disk_usage" =~ ^[0-9]+$ ]]; then
  echo "📊 Current disk usage: ${disk_usage}%"

  if [[ $disk_usage -gt 80 ]]; then
    echo "🚨 CRITICAL: Disk usage is ${disk_usage}% - build may fail due to lack of space!"
    echo "🧹 Running emergency go and docker cleanup..."

    if command -v go >/dev/null 2>&1; then
      echo "🧹 Running Go build cache cleanup..."
      go clean -cache >/dev/null 2>&1 || true
    fi

    if command -v docker >/dev/null 2>&1; then
      # Emergency cleanup - remove stopped containers and dangling images only
      echo "🧹 Emergency cleanup..."
      docker container prune -f >/dev/null 2>&1 || true
      docker image prune -f >/dev/null 2>&1 || true

      # Check if cleanup helped
      if new_usage=$(df -h . 2>/dev/null | tail -1 | awk '{print $5}' 2>/dev/null | sed 's/%//' 2>/dev/null) && [[ -n "$new_usage" ]] && [[ "$new_usage" =~ ^[0-9]+$ ]]; then
        echo "📊 Disk usage after emergency cleanup: ${new_usage}%"

        if [[ $new_usage -gt 85 ]]; then
          echo "❌ Disk usage still critically high after cleanup"
          echo "⚠️  Build may fail due to insufficient disk space"
        else
          echo "✅ Emergency cleanup successful"
        fi
      else
        echo "⚠️  Could not determine disk usage after cleanup"
      fi
    fi
  elif [[ $disk_usage -gt 70 ]]; then
    echo "⚠️  WARNING: Disk usage is ${disk_usage}% - cleanup recommended"
  fi
else
  echo "⚠️  Could not determine disk usage, skipping disk space check"
fi

echo "✅ Build environment setup complete"
