package {{.Provider}}_test

import (
	"context"
	"testing"

	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"

	"{{.Module}}/common/integrations/config"
	"{{.Module}}/internal/integrations/providers/{{.Provider}}"
)

func TestBuilder(t *testing.T) {
	builder := {{.Provider}}.Builder()
	require.NotNil(t, builder)
	assert.Equal(t, {{.Provider}}.Type{{.ProviderPascal}}, builder.Type())
}

func TestBuilderBuild(t *testing.T) {
	loader := config.NewFSLoader(config.ProvidersFS, "providers")
	specs, err := loader.Load()
	require.NoError(t, err)

	spec, ok := specs[{{.Provider}}.Type{{.ProviderPascal}}]
	if !ok {
		t.Skipf("no spec found for provider %q; add common/integrations/config/providers/{{.Provider}}.json", {{.Provider}}.Type{{.ProviderPascal}})
	}

	builder := {{.Provider}}.Builder()
	p, err := builder.Build(context.Background(), spec)
	require.NoError(t, err)
	require.NotNil(t, p)
	assert.Equal(t, {{.Provider}}.Type{{.ProviderPascal}}, p.Type())
}
